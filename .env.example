# fusion-mcp configuration template.
# The server reads plain environment variables (no .env loader is bundled);
# copy this file to .env and source it, or export the values another way.

# Required — base URL of your Fusion board API.
FUSION_BASE_URL=http://127.0.0.1:4040

# Required — Fusion dashboard bearer token.
FUSION_TOKEN=fn_replace_me

# Optional — default project scope for tools that accept a projectId.
#FUSION_DEFAULT_PROJECT_ID=proj_0000000000000000

# Optional — HTTP transport port (default 4141).
#PORT=4141

# Optional — extra allowed Host header values for the HTTP transport
# (comma-separated), e.g. a tunnel hostname.
#FUSION_MCP_ALLOWED_HOSTS=

# Optional — upstream request timeout in milliseconds (default 15000).
#FUSION_REQUEST_TIMEOUT_MS=15000
