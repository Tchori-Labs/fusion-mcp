{
  "name": "fusion-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Governed Model Context Protocol server for a Fusion board",
  "type": "module",
  "bin": {
    "fusion-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts --stdio"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
