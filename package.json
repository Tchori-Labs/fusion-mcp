{
  "name": "@tchori-labs/fusion-mcp",
  "version": "0.1.0",
  "description": "Governed Model Context Protocol server for a Fusion agent board",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "modelcontextprotocol",
    "fusion",
    "agent-board",
    "governance",
    "stdio",
    "ai-agents",
    "claude"
  ],
  "homepage": "https://github.com/Tchori-Labs/fusion-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tchori-Labs/fusion-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Tchori-Labs/fusion-mcp/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "fusion-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "tool-contract.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts --stdio",
    "contract:generate": "tsx scripts/generate-tool-contract.ts",
    "contract:check": "vitest run src/tool-contract.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
