{
  "name": "fusion-mcp",
  "version": "0.1.0",
  "description": "MCP server that wraps the Fusion agent-board REST API — read the board, triage, create tasks, steer agents. No merge/approve/publish powers by design.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "bin": {
    "fusion-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "SPEC.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "dev": "tsx src/index.ts --stdio",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
